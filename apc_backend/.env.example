PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/apc_db
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000

# Set this to true when your hosted PostgreSQL provider requires TLS.
DB_SSL=false

# Optional AI configuration:
# ANTHROPIC_API_KEY=
# OLLAMA_HOST=http://127.0.0.1:11434
